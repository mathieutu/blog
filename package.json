  "devDependencies": {
    "@vuepress/plugin-blog": "^1.0.0-alpha.44",
    "@vuepress/plugin-medium-zoom": "^1.0.0-alpha.44",
    "@vuepress/plugin-pwa": "^1.0.0-alpha.44",
