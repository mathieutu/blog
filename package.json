    "vuepress": "^1.0.0-alpha.44",
    "vuepress-plugin-reading-time": "^0.1.1"
  },
  "scripts": {
    "dev": "vuepress dev src",
    "notify": "osascript -e 'display notification \"Build done\" with title \"Vuepress\"'",
    "build": "vuepress build src && yarn notify",
    "watch": "nodemon -x \"yarn build\" -e js,md,vue,json --ignore '*/dist/*'",
    "check": "serve-my-app --src=src/.vuepress/dist --prod"
  }
